# =============================================================================
# OpenClaw Gateway on Cloud Run — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values for local development.
# For Cloud Run, set these as secrets/env vars in your deployment config.

# REQUIRED: Google Gemini API Key
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# REQUIRED: Gateway authentication token
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# OPTIONAL: Custom system prompt for the AI agent
# OPENCLAW_SYSTEM_PROMPT="You are a helpful assistant."

# OPTIONAL: Port (Cloud Run sets this automatically, default 8080)
# PORT=8080

# =============================================================================
# GCP Deployment Variables (used by CI/CD & manual deploy)
# =============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
CLOUD_RUN_SERVICE=openclaw-gateway
AR_REPOSITORY=openclaw
